{
  "name": "promotions-aggregator",
  "version": "0.1.0",
  "private": true,
  "description": "Take-home: scraper + API + UI for mall promotions.",
  "scripts": {
    "dev:api": "pnpm --filter @promo/api dev",
    "dev:web": "pnpm --filter @promo/web dev",
    "scrape": "pnpm --filter @promo/api scrape",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "onlyBuiltDependencies": ["sharp", "@tailwindcss/oxide", "better-sqlite3"]
  }
}

